<Window x:Class="ShortcutOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <Grid>
        <!-- オーバーレイ本体 -->
        <Border x:Name="OverlayPanel"
                Background="#CC1E1E2E"
                CornerRadius="8"
                Padding="12"
                MinWidth="260"
                MaxWidth="400">
            <StackPanel>
                <!-- ヘッダー -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock x:Name="AppNameLabel"
                               Text="Excel"
                               Foreground="#A0A8FF"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" ショートカット"
                               Foreground="#CCCCDD"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Separator Background="#44FFFFFF" Margin="0,0,0,8"/>

                <!-- ショートカット一覧 (ItemsControl) -->
                <ItemsControl x:Name="ShortcutList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Label}"
                                           Foreground="#DDDDEE"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <Border Grid.Column="1"
                                        Background="#33FFFFFF"
                                        CornerRadius="3"
                                        Padding="4,1"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding KeysDisplay}"
                                               Foreground="#A0FFA0"
                                               FontSize="11"
                                               FontFamily="Consolas"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#8888BB"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Margin="0,6,0,2"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                </ItemsControl>

                <!-- プロセス名表示（デバッグ用） -->
                <TextBlock x:Name="DebugLabel"
                           Foreground="#556655"
                           FontSize="9"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
