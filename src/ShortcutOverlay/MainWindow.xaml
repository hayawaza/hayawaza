<Window x:Class="ShortcutOverlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShortcutOverlay"
        Title="Hayawaza"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <Grid>
        <Border x:Name="OverlayPanel"
                Background="{DynamicResource OverlayPanelBg}"
                CornerRadius="8"
                Padding="12"
                MinWidth="280"
                MaxWidth="420">
            <StackPanel>

                <!-- App name + ホットキーヒント -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock x:Name="AppNameLabel"
                               Text="Excel"
                               Foreground="{DynamicResource OverlayAppName}"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" ショートカット"
                               Foreground="{DynamicResource OverlaySubtitle}"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="右Shift: 表示 / 左Shift: 次"
                               Foreground="{DynamicResource OverlayHint}"
                               FontSize="9"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Right"/>
                </DockPanel>

                <!-- カテゴリ名 + ページ番号 -->
                <DockPanel Margin="0,0,0,6">
                    <TextBlock x:Name="CategoryPageLabel"
                               Text=""
                               Foreground="{DynamicResource OverlayCategoryPage}"
                               FontSize="9"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Right"/>
                    <TextBlock x:Name="CategoryLabel"
                               Text=""
                               Foreground="{DynamicResource OverlayCategoryName}"
                               FontSize="11"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Separator Background="{DynamicResource OverlaySeparator}" Margin="0,0,0,4"/>

                <!-- カテゴリ内ショートカット一覧 -->
                <ItemsControl x:Name="ShortcutList">
                    <ItemsControl.Resources>
                        <DataTemplate x:Key="ShortcutTemplate">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Label}"
                                           Foreground="{DynamicResource OverlayItemLabel}"
                                           FontSize="11"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource OverlayKeyBadgeBg}"
                                        CornerRadius="3"
                                        Padding="4,1"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding KeysDisplay}"
                                               Foreground="{DynamicResource OverlayKeyText}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                        <DataTemplate x:Key="SeparatorTemplate">
                            <Border Height="1"
                                    Background="{DynamicResource OverlaySeparator}"
                                    Opacity="0.4"
                                    Margin="0,3,0,2"/>
                        </DataTemplate>
                    </ItemsControl.Resources>
                    <ItemsControl.ItemTemplateSelector>
                        <local:ShortcutItemTemplateSelector
                            ShortcutTemplate="{StaticResource ShortcutTemplate}"
                            SeparatorTemplate="{StaticResource SeparatorTemplate}"/>
                    </ItemsControl.ItemTemplateSelector>
                </ItemsControl>

                <!-- デバッグ用 -->
                <TextBlock x:Name="DebugLabel"
                           Foreground="{DynamicResource OverlayDebug}"
                           FontSize="9"
                           Margin="0,6,0,0"
                           Visibility="Collapsed"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
