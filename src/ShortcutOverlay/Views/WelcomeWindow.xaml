<Window x:Class="ShortcutOverlay.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hayawaza へようこそ"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#12121C"
        Foreground="#E0E0EC">

    <Window.Resources>
        <Style x:Key="FeatureRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style x:Key="KeyChip" TargetType="Border">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#A100FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C030FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7500C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel Margin="36,30,36,30">

        <!-- ヘッダー -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Image Source="/Assets/icon_logo.png" Width="40" Height="40"
                   VerticalAlignment="Center" Margin="0,0,14,0"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Hayawaza" FontSize="22" FontWeight="Bold" Foreground="#F0F0FF"/>
                <TextBlock Text="インストール完了" FontSize="11" Foreground="#5050A0" Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <TextBlock Text="Excel / PowerPoint のキーボードショートカットを画面に重ねて表示するツールです。"
                   Foreground="#8080B0" FontSize="12" TextWrapping="Wrap" Margin="0,12,0,20"/>

        <!-- 使い方 -->
        <Border Background="#1A1A28" CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="使い方" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <!-- 右Shift -->
                <Grid Style="{StaticResource FeatureRow}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource KeyChip}" Margin="0,0,12,0">
                        <TextBlock Text="右 Shift" Foreground="#A100FF" FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="押している間、ショートカット一覧を表示"
                               Foreground="#B0B0CC" FontSize="12" VerticalAlignment="Center"/>
                </Grid>

                <!-- 左Shift -->
                <Grid Style="{StaticResource FeatureRow}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource KeyChip}" Margin="0,0,12,0">
                        <TextBlock Text="右 Shift + 左 Shift" Foreground="#7000C0" FontFamily="Consolas" FontSize="11"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="カテゴリを切り替え（移動 / 編集 / 書式…）"
                               Foreground="#B0B0CC" FontSize="12" VerticalAlignment="Center"/>
                </Grid>

                <!-- タスクトレイ -->
                <Grid Style="{StaticResource FeatureRow}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource KeyChip}" Margin="0,0,12,0">
                        <TextBlock Text="タスクトレイ" Foreground="#4040A0" FontFamily="Consolas" FontSize="11"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="アイコンをダブルクリックで設定を開く"
                               Foreground="#B0B0CC" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- スタートアップ設定 -->
        <Border Background="#1A1A28" CornerRadius="6" Padding="16,12" Margin="0,0,0,24">
            <StackPanel>
                <CheckBox x:Name="StartupCheck" IsChecked="True" Margin="0,0,0,4">
                    <TextBlock Text="Windows 起動時に自動的に起動する" Foreground="#E0E0EC" FontSize="12"/>
                </CheckBox>
                <TextBlock Text="後から 設定 → 詳細 でも変更できます。"
                           Foreground="#4040A0" FontSize="10" Margin="22,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 始めるボタン -->
        <Button Content="始める" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right" Click="StartButton_Click"/>

    </StackPanel>
</Window>
