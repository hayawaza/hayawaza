<Window x:Class="ShortcutOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutOverlay - 設定"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#1E1E2E"
        Foreground="#CCCCDD">

    <Window.Resources>
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A0A8FF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,4"/>
        </Style>
        <Style x:Key="BodyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCDD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#CCCCDD"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCDD"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#A0A8FF"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A5C"/>
            <Setter Property="Foreground" Value="#CCCCDD"/>
            <Setter Property="BorderBrush" Value="#55AAFFFF"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── 表示モード ── -->
                <TextBlock Text="表示モード" Style="{StaticResource SectionLabel}"/>
                <Separator/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="モード:" Style="{StaticResource BodyLabel}" Width="100"/>
                    <ComboBox x:Name="DisplayModeCombo" Width="160">
                        <ComboBoxItem Tag="always">常時表示</ComboBoxItem>
                        <ComboBoxItem Tag="hotkey">ホットキーで呼び出し</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <StackPanel x:Name="HotkeyPanel" Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="呼び出しキー:" Style="{StaticResource BodyLabel}" Width="100"/>
                    <ComboBox x:Name="HotkeyCombo" Width="200"/>
                </StackPanel>

                <!-- ── ビジュアル調整 ── -->
                <TextBlock Text="ビジュアル" Style="{StaticResource SectionLabel}"/>
                <Separator/>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="透過率:" Style="{StaticResource BodyLabel}"/>
                    <Slider Grid.Column="1" x:Name="OpacitySlider"
                            Minimum="10" Maximum="100" TickFrequency="5"
                            ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="OpacityValueLabel"
                               Style="{StaticResource BodyLabel}" TextAlignment="Right"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="サイズ:" Style="{StaticResource BodyLabel}"/>
                    <Slider Grid.Column="1" x:Name="ScaleSlider"
                            Minimum="50" Maximum="200" TickFrequency="10"
                            ValueChanged="ScaleSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="ScaleValueLabel"
                               Style="{StaticResource BodyLabel}" TextAlignment="Right"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="横位置:" Style="{StaticResource BodyLabel}"/>
                    <Slider Grid.Column="1" x:Name="PosLeftSlider"
                            Minimum="0" Maximum="1800" TickFrequency="50"
                            ValueChanged="PosLeftSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="PosLeftLabel"
                               Style="{StaticResource BodyLabel}" TextAlignment="Right"/>
                </Grid>

                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="縦位置:" Style="{StaticResource BodyLabel}"/>
                    <Slider Grid.Column="1" x:Name="PosTopSlider"
                            Minimum="0" Maximum="1000" TickFrequency="50"
                            ValueChanged="PosTopSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="PosTopLabel"
                               Style="{StaticResource BodyLabel}" TextAlignment="Right"/>
                </Grid>

                <!-- ── ショートカット ON/OFF ── -->
                <TextBlock Text="Excel ショートカット" Style="{StaticResource SectionLabel}"/>
                <Separator/>
                <ItemsControl x:Name="ExcelShortcutList" Margin="0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayText}"
                                      IsChecked="{Binding IsChecked}"
                                      Checked="ShortcutCheck_Changed"
                                      Unchecked="ShortcutCheck_Changed"
                                      Tag="{Binding Id}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="PowerPoint ショートカット" Style="{StaticResource SectionLabel}"/>
                <Separator/>
                <ItemsControl x:Name="PptShortcutList" Margin="0,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding DisplayText}"
                                      IsChecked="{Binding IsChecked}"
                                      Checked="ShortcutCheck_Changed"
                                      Unchecked="ShortcutCheck_Changed"
                                      Tag="{Binding Id}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── デバッグ ── -->
                <TextBlock Text="デバッグ" Style="{StaticResource SectionLabel}"/>
                <Separator/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="対象プロセス:" Style="{StaticResource BodyLabel}" Width="100"/>
                    <TextBox x:Name="DebugProcessBox"
                             Background="#2A2A3E" Foreground="#CCCCDD"
                             BorderBrush="#44FFFFFF"
                             Width="200" Padding="4,2"
                             ToolTip="空欄: excel/powerpnt (既定)。デバッグ時は notepad,calc 等をカンマ区切りで"/>
                </StackPanel>
                <TextBlock Text="空欄の場合は excel / powerpnt が対象です"
                           Foreground="#666677" FontSize="10" Margin="100,0,0,0"/>

                <!-- ── ポーリング間隔 ── -->
                <Grid Margin="0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="50"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ポーリング:" Style="{StaticResource BodyLabel}"/>
                    <Slider Grid.Column="1" x:Name="PollingSlider"
                            Minimum="100" Maximum="1000" TickFrequency="100"
                            ValueChanged="PollingSlider_ValueChanged"/>
                    <TextBlock Grid.Column="2" x:Name="PollingLabel"
                               Style="{StaticResource BodyLabel}" TextAlignment="Right"/>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ── 保存ボタン ── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="キャンセル" Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button Content="保存して閉じる" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
