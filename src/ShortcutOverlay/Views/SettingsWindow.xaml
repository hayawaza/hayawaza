<Window x:Class="ShortcutOverlay.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hayawaza 設定"
        Width="520" Height="700"
        MinWidth="480" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#12121C"
        Foreground="#E0E0EC"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- タブ用 RadioButton -->
        <Style x:Key="NavTab" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9090B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A100FF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#D0D0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- セクション見出し -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,16,0,6"/>
        </Style>

        <!-- ラベル -->
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ヒントテキスト -->
        <Style x:Key="Hint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7070A8"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>

        <!-- カードパネル -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1E1E2E"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <!-- コーナー選択ボタン -->
        <Style x:Key="AnchorBtn" TargetType="RadioButton">
            <Setter Property="Background"      Value="#1A1A2E"/>
            <Setter Property="Foreground"      Value="#7070A0"/>
            <Setter Property="BorderBrush"     Value="#252545"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"  Value="#28285A"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A100FF"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5050A0"/>
                                <Setter Property="Foreground" Value="#C0C0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- スライダーの数値 -->
        <Style x:Key="SliderValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C0C0E8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Width" Value="44"/>
        </Style>

        <!-- ComboBox（完全テンプレート: WPF デフォルトは Win11 テーマで白になるため） -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="#242436"/>
            <Setter Property="Foreground"      Value="#D0D0E8"/>
            <Setter Property="BorderBrush"     Value="#303050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="Root">
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#1A1A2C" BorderBrush="#303050" BorderThickness="1"
                                        CornerRadius="3"
                                        MinWidth="{Binding ActualWidth, ElementName=Root}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center" IsHitTestVisible="False"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Grid.Column="1" Text="▾" FontSize="9" Foreground="#6060A0"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <!-- 透明クリック領域 -->
                            <ToggleButton Background="Transparent" BorderThickness="0" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"    Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#5050A0"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A100FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D0D0E8"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2A48"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30305E"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#242436"/>
            <Setter Property="Foreground" Value="#D0D0E8"/>
            <Setter Property="BorderBrush" Value="#303050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CaretBrush" Value="#A100FF"/>
        </Style>

        <!-- Slider -->
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#A100FF"/>
            <Setter Property="Height" Value="20"/>
        </Style>

        <!-- プライマリボタン -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#A100FF"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#C030FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#7500C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- セカンダリボタン -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7878A0"/>
            <Setter Property="BorderBrush" Value="#303050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C0C0E0"/>
                                <Setter Property="BorderBrush" Value="#6060A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 追加ボタン（小） -->
        <Style x:Key="AddButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#5050A0"/>
            <Setter Property="BorderBrush" Value="#282840"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#A100FF"/>
                                <Setter Property="BorderBrush" Value="#A100FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#12121C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── ヘッダー ── -->
        <Border Grid.Row="0" Background="#0C0C16" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <Image Source="/Assets/icon_logo.png" Width="28" Height="28"
                       VerticalAlignment="Center" Margin="0,0,8,0"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock Text="Hayawaza" FontSize="16" FontWeight="Bold"
                           Foreground="#F0F0FF" VerticalAlignment="Center"/>
                <TextBlock Text=" 設定" FontSize="16" Foreground="#444460"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── タブバー ── -->
        <Border Grid.Row="1" Background="#0C0C16"
                BorderBrush="#1E1E30" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,0">
                <RadioButton x:Name="TabVisual"     Content="表示"          Style="{StaticResource NavTab}" IsChecked="True" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabShortcuts"  Content="ショートカット" Style="{StaticResource NavTab}" Checked="Tab_Checked"/>
                <RadioButton x:Name="TabAdvanced"   Content="詳細"          Style="{StaticResource NavTab}" Checked="Tab_Checked"/>
            </StackPanel>
        </Border>

        <!-- ── コンテンツ ── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20,0">

                <!-- 表示タブ -->
                <StackPanel x:Name="PageVisual" Margin="0,4,0,16">

                    <TextBlock Text="動作" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="表示モード" Style="{StaticResource Label}"/>
                                <ComboBox Grid.Column="1" x:Name="DisplayModeCombo">
                                    <ComboBoxItem Tag="always">常時表示</ComboBoxItem>
                                    <ComboBoxItem Tag="hotkey">ホットキーで呼び出し</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Grid x:Name="HotkeyPanel" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="呼び出しキー" Style="{StaticResource Label}"/>
                                <ComboBox Grid.Column="1" x:Name="HotkeyCombo" Width="180" HorizontalAlignment="Left"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="テーマ・見た目" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="カラーテーマ" Style="{StaticResource Label}"/>
                                <ComboBox Grid.Column="1" x:Name="ThemeCombo">
                                    <ComboBoxItem Tag="dark">ダーク</ComboBoxItem>
                                    <ComboBoxItem Tag="white">ホワイト</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="透過率" Style="{StaticResource Label}"/>
                                <Slider Grid.Column="1" x:Name="OpacitySlider" Minimum="10" Maximum="100" TickFrequency="5" ValueChanged="OpacitySlider_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="OpacityValueLabel" Style="{StaticResource SliderValue}"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="サイズ" Style="{StaticResource Label}"/>
                                <Slider Grid.Column="1" x:Name="ScaleSlider" Minimum="50" Maximum="200" TickFrequency="10" ValueChanged="ScaleSlider_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="ScaleValueLabel" Style="{StaticResource SliderValue}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="表示位置" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- 4コーナー選択 -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <RadioButton Grid.Row="0" Grid.Column="0" x:Name="AnchorTopLeft"
                                             Content="↖ 左上" GroupName="Anchor"
                                             Style="{StaticResource AnchorBtn}"/>
                                <RadioButton Grid.Row="0" Grid.Column="1" x:Name="AnchorTopRight"
                                             Content="↗ 右上" GroupName="Anchor"
                                             Style="{StaticResource AnchorBtn}"/>
                                <RadioButton Grid.Row="1" Grid.Column="0" x:Name="AnchorBottomLeft"
                                             Content="↙ 左下" GroupName="Anchor"
                                             Style="{StaticResource AnchorBtn}"/>
                                <RadioButton Grid.Row="1" Grid.Column="1" x:Name="AnchorBottomRight"
                                             Content="↘ 右下" GroupName="Anchor"
                                             Style="{StaticResource AnchorBtn}"/>
                            </Grid>
                            <!-- コーナーからの余白 -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="余白" Style="{StaticResource Label}"/>
                                <Slider Grid.Column="1" x:Name="MarginSlider" Minimum="0" Maximum="200" TickFrequency="10" ValueChanged="MarginSlider_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="MarginLabel" Style="{StaticResource SliderValue}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ショートカットタブ -->
                <StackPanel x:Name="PageShortcuts" Visibility="Collapsed" Margin="0,4,0,16">

                    <TextBlock Text="Excel" Style="{StaticResource SectionTitle}"/>
                    <!-- グループはcode-behindで構築 -->
                    <StackPanel x:Name="ExcelGroupsPanel"/>

                    <Button x:Name="ExcelAddBtn" Content="＋ ショートカットを追加"
                            Style="{StaticResource AddButton}"
                            HorizontalAlignment="Left" Margin="0,6,0,0"
                            Click="ShowAddPanel_Click" Tag="excel"/>
                    <Border x:Name="ExcelAddPanel" Visibility="Collapsed"
                            Background="#1A1A28" CornerRadius="6"
                            Padding="14,12" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="ショートカットを追加 — Excel"
                                       Foreground="#6060A0" FontSize="10" Margin="0,0,0,10"/>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="カテゴリ *" Style="{StaticResource Label}" FontSize="11" ToolTip="新しいカテゴリ名を直接入力することも可能です"/>
                                <ComboBox Grid.Column="1" x:Name="ExcelAddCategory" IsEditable="True"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ラベル" Style="{StaticResource Label}" FontSize="11"/>
                                <TextBox Grid.Column="1" x:Name="ExcelAddLabel" MaxLength="60"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="キー" Style="{StaticResource Label}" FontSize="11"/>
                                <TextBox Grid.Column="1" x:Name="ExcelAddKeys" MaxLength="80"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="種別" Style="{StaticResource Label}" FontSize="11"/>
                                <ComboBox Grid.Column="1" x:Name="ExcelAddKeyType">
                                    <ComboBoxItem Tag="combo" IsSelected="True">同時押し (Ctrl+K)</ComboBoxItem>
                                    <ComboBoxItem Tag="sequence">順押し (Alt→H→B)</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="キーはカンマ区切りで入力  例: Ctrl,K / Alt,H,B,A"
                                       Style="{StaticResource Hint}" Margin="80,0,0,2"/>
                            <TextBlock Text="* カテゴリは既存を選択するか、新しい名前を直接入力して作成できます"
                                       Style="{StaticResource Hint}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button Content="キャンセル" Style="{StaticResource SecondaryButton}" Padding="12,6" Click="CancelAddPanel_Click" Tag="excel"/>
                                <Button Content="追加" Style="{StaticResource PrimaryButton}" Padding="16,6" Margin="8,0,0,0" Click="AddShortcut_Click" Tag="excel"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="PowerPoint" Style="{StaticResource SectionTitle}"/>
                    <StackPanel x:Name="PptGroupsPanel"/>

                    <Button x:Name="PptAddBtn" Content="＋ ショートカットを追加"
                            Style="{StaticResource AddButton}"
                            HorizontalAlignment="Left" Margin="0,6,0,0"
                            Click="ShowAddPanel_Click" Tag="powerpnt"/>
                    <Border x:Name="PptAddPanel" Visibility="Collapsed"
                            Background="#1A1A28" CornerRadius="6"
                            Padding="14,12" Margin="0,4,0,0">
                        <StackPanel>
                            <TextBlock Text="ショートカットを追加 — PowerPoint"
                                       Foreground="#6060A0" FontSize="10" Margin="0,0,0,10"/>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="カテゴリ *" Style="{StaticResource Label}" FontSize="11" ToolTip="新しいカテゴリ名を直接入力することも可能です"/>
                                <ComboBox Grid.Column="1" x:Name="PptAddCategory" IsEditable="True"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ラベル" Style="{StaticResource Label}" FontSize="11"/>
                                <TextBox Grid.Column="1" x:Name="PptAddLabel" MaxLength="60"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="キー" Style="{StaticResource Label}" FontSize="11"/>
                                <TextBox Grid.Column="1" x:Name="PptAddKeys" MaxLength="80"/>
                            </Grid>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="種別" Style="{StaticResource Label}" FontSize="11"/>
                                <ComboBox Grid.Column="1" x:Name="PptAddKeyType">
                                    <ComboBoxItem Tag="combo" IsSelected="True">同時押し (Ctrl+K)</ComboBoxItem>
                                    <ComboBoxItem Tag="sequence">順押し (Alt→H→B)</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="キーはカンマ区切りで入力  例: Ctrl,K / Alt,H,B,A"
                                       Style="{StaticResource Hint}" Margin="80,0,0,2"/>
                            <TextBlock Text="* カテゴリは既存を選択するか、新しい名前を直接入力して作成できます"
                                       Style="{StaticResource Hint}" Margin="0,0,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                <Button Content="キャンセル" Style="{StaticResource SecondaryButton}" Padding="12,6" Click="CancelAddPanel_Click" Tag="powerpnt"/>
                                <Button Content="追加" Style="{StaticResource PrimaryButton}" Padding="16,6" Margin="8,0,0,0" Click="AddShortcut_Click" Tag="powerpnt"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 詳細タブ -->
                <StackPanel x:Name="PageAdvanced" Visibility="Collapsed" Margin="0,4,0,16">

                    <TextBlock Text="起動" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource Card}">
                        <CheckBox x:Name="StartupCheck">
                            <TextBlock Text="Windows 起動時に自動的に起動する" Foreground="#E0E0EC" FontSize="12"/>
                        </CheckBox>
                    </Border>

                    <TextBlock Text="パフォーマンス" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ポーリング間隔" Style="{StaticResource Label}"/>
                            <Slider Grid.Column="1" x:Name="PollingSlider" Minimum="100" Maximum="1000" TickFrequency="100" ValueChanged="PollingSlider_ValueChanged"/>
                            <TextBlock Grid.Column="2" x:Name="PollingLabel" Style="{StaticResource SliderValue}"/>
                        </Grid>
                    </Border>

                    <TextBlock Text="バージョン情報" Style="{StaticResource SectionTitle}"/>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Hayawaza 早業" Style="{StaticResource Label}"/>
                            <TextBlock Grid.Column="1" x:Name="VersionLabel" Text="" Foreground="#404060" FontSize="11" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- ── フッター ── -->
        <Border Grid.Row="3" Background="#0C0C16"
                BorderBrush="#1E1E30" BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="キャンセル" Style="{StaticResource SecondaryButton}" Click="CancelButton_Click"/>
                <Button Content="保存して適用" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Click="SaveButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
